# ============================
# ENTORNO
# ============================
NODE_ENV=local
PORT=3000

# ============================
# BASE DE DATOS LOCAL
# ============================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=cosmeticos_db
POSTGRES_USER=admin
POSTGRES_PASSWORD=cosmeticos2026
